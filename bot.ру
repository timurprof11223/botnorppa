# ====== ЛОГИКА ПОБЕДИТЕЛЯ (при равенстве — по приоритету A > B > V > G) ======
def get_winner(counts: dict) -> str:
    order = ["A", "B", "V", "G"]
    best = order[0]
    for k in order[1:]:
        if counts[k] > counts[best]:
            best = k
    return best


# ====== БАЗА ДАННЫХ СТАТИСТИКИ ======
async def init_db():
    async with aiosqlite.connect(DB_PATH) as db:
        await db.execute("""
            CREATE TABLE IF NOT EXISTS results_stats (
                key TEXT PRIMARY KEY,
                count INTEGER NOT NULL
            )
        """)
        # гарантируем строки
        for k in ["A", "B", "V", "G"]:
            await db.execute(
                "INSERT OR IGNORE INTO results_stats (key, count) VALUES (?, 0)",
                (k,)
            )
        await db.commit()

async def inc_stat(key: str):
    async with aiosqlite.connect(DB_PATH) as db:
        await db.execute(
            "UPDATE results_stats SET count = count + 1 WHERE key = ?",
            (key,)
        )
        await db.commit()

async def get_stats() -> Dict[str, int]:
    async with aiosqlite.connect(DB_PATH) as db:
        cur = await db.execute("SELECT key, count FROM results_stats")
        rows = await cur.fetchall()
        return {k: int(v) for k, v in rows}


# ====== ОТПРАВКА ВОПРОСА С ФОТО (фото сверху, текст снизу, кнопки ниже) ======
async def send_question(call_or_msg, user_id: int, q_index: int):
    photo_id = Q_PHOTOS[q_index]
    text = QUESTIONS[q_index]

    # отправляем фото с подписью (в подписи будет вопрос)
    if isinstance(call_or_msg, CallbackQuery):
        chat = call_or_msg.message.chat.id
        bot = call_or_msg.bot
    else:
        chat = call_or_msg.chat.id
        bot = call_or_msg.bot

    await bot.send_photo(
        chat_id=chat,
        photo=photo_id,
        caption=text,
        reply_markup=answers_keyboard()
    )


async def main():
    if not TOKEN:
        raise RuntimeError("BOT_TOKEN is empty. Set Railway Variable BOT_TOKEN")

    bot = Bot(TOKEN)
    dp = Dispatcher()

    await init_db()

    # /start — присылаем ВСТУП С ФОТО + кнопку Начать
    @dp.message(Command("start"))
    async def cmd_start(message: Message):
        USER_STATE.pop(message.from_user.id, None)

        await message.answer_photo(
            photo=INTRO_PHOTO_ID,
            caption=INTRO_TEXT,
            reply_markup=start_keyboard()
        )

    # Большая кнопка "Начать тест"
    @dp.callback_query(F.data == "start_quiz")
    async def start_quiz(call: CallbackQuery):
        user_id = call.from_user.id
        USER_STATE[user_id] = {"q": 0, "counts": {"A": 0, "B": 0, "V": 0, "G": 0}}
        await call.answer()
        await send_question(call, user_id, 0)

    # Ответы
    @dp.callback_query(F.data.startswith("ans:"))
    async def answer(call: CallbackQuery):
        user_id = call.from_user.id
        if user_id not in USER_STATE:
            await call.answer("Нажмите /start", show_alert=True)
            return

        letter = call.data.split(":")[1]
        st = USER_STATE[user_id]
        st["counts"][letter] += 1
        st["q"] += 1
        q_index = st["q"]

        await call.answer()

        # убираем кнопки с предыдущего вопроса, чтобы не жали повторно
        try:
            await call.message.edit_reply_markup(reply_markup=None)
        except Exception:
            pass

        if q_index < len(QUESTIONS):
            await send_question(call, user_id, q_index)
        else:
            winner = get_winner(st["counts"])

            # записываем статистику
            await inc_stat(winner)

            # отправляем РЕЗУЛЬТАТ: фото сверху, текст в подписи
            await call.message.answer_photo(
                photo=RESULT_PHOTO[winner],
                caption=RESULT_TEXT[winner],
                reply_markup=promo_keyboard()
            )

    # Промокод
    @dp.callback_query(F.data == "get_promo")
    async def give_promo(call: CallbackQuery):
        await call.answer()
        await call.message.answer(PROMO_TEXT, reply_markup=restart_keyboard())
        USER_STATE.pop(call.from_user.id, None)

    # Пройти ещё раз
    @dp.callback_query(F.data == "restart_quiz")
    async def restart(call: CallbackQuery):
        user_id = call.from_user.id
        USER_STATE[user_id] = {"q": 0, "counts": {"A": 0, "B": 0, "V": 0, "G": 0}}
        await call.answer()
        await send_question(call, user_id, 0)

    # /stats — только админам
    @dp.message(Command("stats"))
    async def stats_cmd(message: Message):
        if ADMIN_IDS and message.from_user.id not in ADMIN_IDS:
            await message.answer("Нет доступа.")
            return

        s = await get_stats()
        total = sum(s.values())

        text = (
            "📊 Статистика результатов\n\n"
            f"A: {s.get('A', 0)}\n"
            f"Б: {s.get('B', 0)}\n"
            f"В: {s.get('V', 0)}\n"
            f"Г: {s.get('G', 0)}\n\n"
            f"Всего завершили тест: {total}"
        )
        await message.answer(text)

    await dp.start_polling(bot)


if __name__ == "__main__":
    asyncio.run(main())


