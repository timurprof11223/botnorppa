# =========================
# КНОПКИ
# =========================
def main_keyboard_start():
    return ReplyKeyboardMarkup(
        keyboard=[[KeyboardButton(text="Начать тест")]],
        resize_keyboard=True
    )


def main_keyboard_restart():
    return ReplyKeyboardMarkup(
        keyboard=[[KeyboardButton(text="Пройти ещё раз")]],
        resize_keyboard=True
    )


def answers_keyboard():
    kb = InlineKeyboardBuilder()
    kb.button(text="А", callback_data="ans:A")
    kb.button(text="Б", callback_data="ans:B")
    kb.button(text="В", callback_data="ans:V")
    kb.button(text="Г", callback_data="ans:G")
    kb.adjust(4)
    return kb.as_markup()


def promo_keyboard():
    kb = InlineKeyboardBuilder()
    kb.button(text="Забрать промокод", callback_data="get_promo")
    kb.adjust(1)
    return kb.as_markup()


def get_winner(counts: dict) -> str:
    order = ["A", "B", "V", "G"]
    best = order[0]
    for k in order[1:]:
        if counts[k] > counts[best]:
            best = k
    return best


# =========================
# ОТПРАВКА (фото отдельно)
# =========================
async def safe_photo(message: Message, file_id: str, tag: str):
    try:
        await message.answer_photo(photo=file_id)
    except Exception as e:
        logging.exception("Не смог отправить фото %s: %s", tag, e)
        await message.answer(f"⚠️ Не смог отправить фото ({tag}). Ошибка:\n{e}")


async def show_intro(message: Message):
    USER_STATE.pop(message.from_user.id, None)
    await safe_photo(message, INTRO_PHOTO_ID, "INTRO")
    await message.answer(INTRO_TEXT, reply_markup=main_keyboard_start())


async def start_quiz_for_user(message: Message):
    USER_STATE[message.from_user.id] = {"q": 0, "counts": {"A": 0, "B": 0, "V": 0, "G": 0}}
    # убираем большую кнопку во время теста
    await message.answer("Поехали! 🚀", reply_markup=ReplyKeyboardRemove())
    await send_question(message, 0)


async def send_question(message: Message, q_index: int):
    await safe_photo(message, QUESTION_PHOTOS[q_index], f"Q{q_index+1}")
    await message.answer(QUESTIONS[q_index], reply_markup=answers_keyboard())


async def send_result(message: Message, winner: str):
    await safe_photo(message, RESULT_PHOTOS[winner], f"RESULT-{winner}")
    await message.answer(RESULT_TEXTS[winner], reply_markup=promo_keyboard())


# =========================
# MAIN
# =========================
async def main():
    logging.basicConfig(level=logging.INFO)

    bot = Bot(TOKEN)
    dp = Dispatcher()

    # /start -> показать интро и кнопку "Начать тест"
    @dp.message(Command("start"))
    async def cmd_start(message: Message):
        await show_intro(message)

    # Нажатие большой кнопки "Начать тест" -> старт теста
    @dp.message(F.text == "Начать тест")
    async def start_from_button(message: Message):
        await start_quiz_for_user(message)

    # Нажатие большой кнопки "Пройти ещё раз" -> новый тест (сразу, без интро)
    @dp.message(F.text == "Пройти ещё раз")
    async def restart_from_button(message: Message):
        await start_quiz_for_user(message)

    # ответы
    @dp.callback_query(F.data.startswith("ans:"))
    async def answer(call: CallbackQuery):
        user_id = call.from_user.id
        if user_id not in USER_STATE:
            await call.answer("Нажмите «Начать тест»", show_alert=True)
            return

        letter = call.data.split(":")[1]  # A/B/V/G
        st = USER_STATE[user_id]
        st["counts"][letter] += 1
        st["q"] += 1
        q_index = st["q"]

        await call.answer()

        # убрать кнопки у сообщения с вопросом
        try:
            await call.message.edit_reply_markup(reply_markup=None)
        except Exception:
            pass

        if q_index < len(QUESTIONS):
            await send_question(call.message, q_index)
        else:
            winner = get_winner(st["counts"])
            await send_result(call.message, winner)

    # промокод
    @dp.callback_query(F.data == "get_promo")
    async def give_promo(call: CallbackQuery):
        await call.answer()
        await call.message.answer(PROMO_TEXT, reply_markup=main_keyboard_restart())
        USER_STATE.pop(call.from_user.id, None)

    await dp.start_polling(bot)


if __name__ == "__main__":
    asyncio.run(main())